SSH_GATEWAY_IMAGE=ghcr.io/dnviti/arsenale/ssh-gateway:latest
SSH_GATEWAY_CONTAINER_NAME=arsenale-ssh-gateway
SSH_PORT=2222
SSH_AUTHORIZED_KEYS=ssh-ed25519 CHANGE_ME

TUNNEL_SERVER_URL=https://arsenale.example.com
TUNNEL_TOKEN=CHANGE_ME
TUNNEL_GATEWAY_ID=CHANGE_ME
TUNNEL_LOCAL_HOST=127.0.0.1
TUNNEL_LOCAL_PORT=2222
TUNNEL_CLIENT_CERT_FILE=./certs/tunnel-client-cert.pem
TUNNEL_CLIENT_KEY_FILE=./certs/tunnel-client-key.pem

SPIFFE_TRUST_DOMAIN=arsenale.local
GATEWAY_GRPC_EXPECTED_SPIFFE_ID=spiffe://arsenale.local/service/control-plane-api
GATEWAY_GRPC_TLS_CA_FILE=./grpc-certs/ca.pem
GATEWAY_GRPC_CLIENT_CA_FILE=./grpc-certs/client-ca.pem
GATEWAY_GRPC_TLS_CERT_FILE=./grpc-certs/server-cert.pem
GATEWAY_GRPC_TLS_KEY_FILE=./grpc-certs/server-key.pem
