TUNNEL_AGENT_IMAGE=ghcr.io/dnviti/arsenale/tunnel-agent:latest
TUNNEL_AGENT_CONTAINER_NAME=arsenale-tunnel-agent

# Transport: "wss" (default, WebSocket frame-mux) or "quic" (QUIC native streams).
TUNNEL_TRANSPORT=wss

TUNNEL_SERVER_URL=https://arsenale.example.com
TUNNEL_TOKEN=CHANGE_ME
TUNNEL_GATEWAY_ID=CHANGE_ME
TUNNEL_LOCAL_HOST=host.docker.internal
TUNNEL_LOCAL_PORT=4822
TUNNEL_CLIENT_CERT_FILE=./certs/tunnel-client-cert.pem
TUNNEL_CLIENT_KEY_FILE=./certs/tunnel-client-key.pem

# QUIC transport (TUNNEL_TRANSPORT=quic): the broker's UDP host:port plus the CA
# that signed the broker's QUIC server certificate. TUNNEL_QUIC_SERVER_NAME is
# optional and overrides the TLS SNI / server-cert name when it differs from the
# dial host.
# TUNNEL_QUIC_SERVER_ADDR=arsenale.example.com:8093
# TUNNEL_QUIC_SERVER_NAME=tunnel-broker
# TUNNEL_CA_CERT_FILE=./certs/tunnel-ca.pem
