RDGW_IMAGE=ghcr.io/dnviti/arsenale/rdgw:latest
RDGW_CONTAINER_NAME=arsenale-rdgw
RDGW_BIND_HOST=0.0.0.0
RDGW_HOST_PORT=443
RDGW_ARSENALE_API_URL=https://arsenale.example.com
RDGW_API_TOKEN=CHANGE_ME
RDGW_TLS_CERT_FILE=./certs/rdgw-server-cert.pem
RDGW_TLS_KEY_FILE=./certs/rdgw-server-key.pem
RDGW_IDLE_TIMEOUT=3600
RDGW_LOG_LEVEL=info
